+fn acknowledge_reaches_authority_and_never_filter_update() {
+    let mut executive = Executive::new(
+        Config {
+            gnss_authority: GnssAuthority::Off,
+            oneweb_enabled: false,
+        },
+        ManualClock::default(),
+        FilterStub::default(),
