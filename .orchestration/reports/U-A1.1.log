+#[derive(Debug)]
+struct ScriptedClock(std::collections::VecDeque<u64>);
+
+impl pnt_time::ClockService for ScriptedClock {
+    fn ingress_monotonic_ns(&mut self) -> u64 {
+        self.0.pop_front().expect("clock script exhausted")
+    }
+}
