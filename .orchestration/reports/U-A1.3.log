+
+    s.acknowledge(104);
+    assert_eq!(s.state(), S::LatchedSafe);
+    arm(&mut s, 1_000_000_103);
+    solution(&mut s, 4, 1_000_000_103, &good);
+    assert_eq!(s.state(), S::LatchedSafe, "rearm dwell is not yet complete");
