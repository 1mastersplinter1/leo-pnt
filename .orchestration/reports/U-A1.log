+    Caution,
+    Warning,
+    Escalated,
+    LatchedSafe,
+}
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub enum AuthorityEvent {
+    Disarm,
+    Arm,
+    G2Fall,
+    G2Rise,
+    G3Fall,
+    G3Rise,
+    LeaseExpiry,
+    AckTimeout,
+    Acknowledge,
+    CautionEnter,
