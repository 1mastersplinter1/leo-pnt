+    s.acknowledge(2);
+    arm(&mut s, 3);
+    solution(&mut s, 4, 1_000_000_001, &good);
+    assert!(!s.steering_authorised(&good, 1_000_000_001));
+    solution(&mut s, 5, 1_000_000_002, &good);
+    assert!(s.steering_authorised(&good, 1_000_000_002));
+}
