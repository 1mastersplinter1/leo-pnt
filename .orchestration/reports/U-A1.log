+    match (state, event) {
+        (S::Disarmed, E::Arm) | (S::LatchedSafe, E::Arm) if arm_guard => S::Nominal,
+        (S::Nominal | S::Caution, E::Disarm) => S::Disarmed,
+        (S::Nominal | S::Caution, E::G2Fall | E::G3Fall | E::LeaseExpiry) => S::Warning,
+        (S::Nominal, E::CautionEnter) => S::Caution,
