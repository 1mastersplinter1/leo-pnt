+}
+
+#[derive(Clone, Copy, Debug, Default)]
+pub struct IntegrityStub;
+
+impl IntegrityAuthorityGate for IntegrityStub {
+    fn steering_authorised(&mut self, _state: &FilterState, _monotonic_ns: u64) -> bool {
+        true
+    }
+}
