+        assert!(numeric[(0, VEL + 2)].abs() > 1.0e-3);
+    }
+
+    #[test]
+    fn estimator_update_dispatches_every_payload_type() {
+        let cases = [
+            (MeasurementPayload::Imu(ImuSample::default()), 0),
+            (MeasurementPayload::Heading(Heading { radians: 0.2 }), 1),
+            (
