+            for column in 0..self.covariance.ncols() {
+                self.covariance[(index, column)] *= scale;
+            }
+            for row in 0..self.covariance.nrows() {
+                self.covariance[(row, index)] *= scale;
+            }
+            self.covariance[(index, index)] = CLOCK_BIAS_VARIANCE_CAP_M2;
+        }
+    }
