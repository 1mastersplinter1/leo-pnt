+                    correlation_peak_hz: 1.0,
+                    nominal_carrier_hz: 2.0,
+                }),
+                0,
+            ),
+            (
+                MeasurementPayload::ArmCommand(ArmCommand {
+                    action: ArmAction::Arm,
+                    host_monotonic_ns: 1,
+                    source_id: SourceId("helm".into()),
+                }),
+                0,
+            ),
+        ];
+        for (payload, expected_updates) in cases {
