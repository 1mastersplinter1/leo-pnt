+
+fn covariance_accuracy(covariance: &[f64], dimension: usize, indices: &[usize]) -> f64 {
+    indices
+        .iter()
+        .filter_map(|index| covariance.get(index * dimension + index))
+        .copied()
+        .fold(0.0_f64, f64::max)
+        .max(0.0)
+        .sqrt()
