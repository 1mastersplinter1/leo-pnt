+    fn transition_matrix(&self, dt: f64) -> DMatrix<f64> {
+        let mut f = DMatrix::identity(self.x.len(), self.x.len());
+        for axis in 0..3 {
+            f[(POS + axis, VEL + axis)] = dt;
+        }
+        f[(CLOCK_BIAS, CLOCK_DRIFT)] = dt;
+        f
+    }
+
+    fn debug_assert_covariance(&self) {
