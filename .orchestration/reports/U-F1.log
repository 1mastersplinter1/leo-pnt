+    const FD_STEP: f64 = 1.0e-6;
+    const JACOBIAN_TOLERANCE: f64 = 2.0e-6;
+
+    fn central_difference(function: impl Fn(&DVector<f64>) -> DVector<f64>, x: &DVector<f64>) -> DMatrix<f64> {
+        let output = function(x);
+        let mut result = DMatrix::zeros(output.len(), x.len());
+        for column in 0..x.len() {
+            let mut plus = x.clone(); plus[column] += FD_STEP;
+            let mut minus = x.clone(); minus[column] -= FD_STEP;
+            result.set_column(column, &((function(&plus) - function(&minus)) / (2.0 * FD_STEP)));
+        }
+        result
+    }
+
