+        let numeric_speed =
+            central_difference(|value| DVector::from_element(1, speed_model(value).0), &x);
+        assert!((numeric_speed.row(0).transpose() - speed_h).amax() < JACOBIAN_TOLERANCE);
+
+        for index in 0..CORE_DIM {
