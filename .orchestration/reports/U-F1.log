diff --git a/.orchestration/CONTRACTS.md b/.orchestration/CONTRACTS.md
index fafcb35d89acc312738c25924a2f9d7dc7614f4e..f43b63572a0f92e26ceb5270d3f197a97e377590
--- a/.orchestration/CONTRACTS.md
