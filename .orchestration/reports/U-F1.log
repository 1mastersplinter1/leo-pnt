+            variance_mps2: 1.0,
+            chi_square_threshold: Some(10.0),
+        });
+        assert!(result.accepted);
+        assert_eq!(filter.covariance().nrows(), core + 1);
+        assert!(filter.retire_satellite_bias("SV-1"));
+        assert_eq!(filter.covariance().nrows(), core);
+    }
+
