+        let ph = &self.covariance * h;
+        let innovation_variance = h.dot(&ph) + variance;
+        let nis = innovation * innovation / innovation_variance;
+        let accepted = gate.is_none_or(|threshold| nis <= threshold);
+        if accepted {
