+        let mut filter = FilterStub::default();
+        let before = filter.state();
+        let result = filter.update_heading(Heading { radians: 3.0 }, 0.01, Some(1.0));
+        assert!(!result.accepted);
+        assert_eq!(filter.state(), before);
+    }
