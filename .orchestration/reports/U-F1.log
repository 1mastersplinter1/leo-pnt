+    pub fn update_msl_altitude(&mut self, update: MslAltitudeUpdate) -> UpdateResult {
+        let mut h = DVector::zeros(self.x.len());
+        h.rows_mut(POS, 3)
+            .copy_from(&DVector::from_column_slice(&update.up_ecef));
+        let predicted = update
+            .up_ecef
