+            .max(f64::EPSILON);
+        match measurement.payload {
+            MeasurementPayload::Heading(value) => {
+                self.update_heading(value, variance, None);
+            }
+            MeasurementPayload::SpeedThroughWater(value) => {
+                self.update_speed_through_water(value, variance, None);
+            }
+            _ => {}
+        }
     }
 
