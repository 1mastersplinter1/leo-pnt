+        let filter = FilterStub::default();
+        let dt = 0.01;
+        let numeric = central_difference(|x| {
+            let mut y = x.clone();
+            for axis in 0..3 { y[POS + axis] += x[VEL + axis] * dt; }
+            y[CLOCK_BIAS] += x[CLOCK_DRIFT] * dt; y
+        }, &DVector::from_iterator(CORE_DIM, (1..=CORE_DIM).map(f64::from)));
+        assert!((numeric - filter.transition_matrix(dt)).amax() < JACOBIAN_TOLERANCE);
+    }
+
