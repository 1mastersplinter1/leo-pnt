+fn speed_model(x: &DVector<f64>) -> (f64, DVector<f64>) {
+    let speed = x[VEL].hypot(x[VEL + 1]);
+    let mut h = DVector::zeros(x.len());
+    if speed > 1.0e-12 {
+        h[VEL] = x[VEL] / speed;
+        h[VEL + 1] = x[VEL + 1] / speed;
+    }
+    (speed, h)
