+    pub fn reserve_receiver_clock(&mut self, id: ReceiverClockId) -> ReceiverClockSlot {
+        if let Some(slot) = self.receiver_clocks.get(&id) {
+            return *slot;
+        }
+        let bias_index = self.augment_state(0.0, 1.0e6);
