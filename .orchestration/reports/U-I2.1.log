+    fn update(&mut self, _: &MeasurementEnvelope) {}
+    fn state(&self) -> FilterState { FilterState { heading_rad: f64::NAN, ..FilterState::default() } }
+    fn update_predicted_doppler(&mut self, _: &pnt_estimator::DopplerRangeRateUpdate) -> pnt_estimator::UpdateResult { unreachable!() }
+}
+
+#[test]
+fn non_finite_epoch_is_not_emitted_and_is_journalled() {
+    let mut executive = Executive::new(
+        Config { gnss_authority: GnssAuthority::Off, oneweb_enabled: false },
+        ManualClock::default(), PoisonedEstimator, IntegrityStub, MemoryJournals::default());
+    executive.process(envelope(1, MeasurementPayload::Heading(Heading { radians: 0.2 })));
+    assert!(executive.take_solution_lines().is_empty());
+    assert!(executive.take_solution_epochs().is_empty());
+    assert!(executive.journals().integrity_events()[0].reason.contains("non-finite"));
+}
