+    UnknownSchemaVersion { path: PathBuf, version: u16 },
+    CorruptRecord { path: PathBuf, offset: u64, reason: &'static str },
+    Codec(&'static str),
+    WriterFailed,
+}
+
+impl fmt::Display for JournalError {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        write!(f, "{self:?}")
