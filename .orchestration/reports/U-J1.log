+    e.u16(x.schema_version);e.string(&x.source_id.0)?;e.u64(x.sequence);match x.sample_time{TimeTag::DeviceNanoseconds(v)=>{e.u8(1);e.u64(v)},TimeTag::HostMonotonicNanoseconds(v)=>{e.u8(2);e.u64(v)}}e.u64(x.host_receive_monotonic_ns);
