+    }
+    pub fn finalize(mut self) -> Result<RunManifest, JournalError> {
+        for slot in [&mut self.measurement, &mut self.truth] { if let Some(writer) = slot.take() { let (file, _) = writer.finish()?; self.manifest.files.push(file); } }
+        self.manifest.files.sort_by(|a, b| a.path.cmp(&b.path)); write_manifest(&self.root, &self.manifest)?; Ok(self.manifest)
