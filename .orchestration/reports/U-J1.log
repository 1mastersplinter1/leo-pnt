+fn segment_paths(root: &Path, kind: StreamKind, ext: &str) -> Result<Vec<PathBuf>, JournalError> {
+    let mut out = Vec::new(); for e in fs::read_dir(root)? { let p = e?.path(); let name = p.file_name().and_then(|x| x.to_str()).unwrap_or(""); if name.starts_with(kind.prefix()) && p.extension().and_then(|x| x.to_str()) == Some(ext) { out.push(p); } } Ok(out)
