+fn u8_to_frame(v:u8)->Result<Frame,JournalError>{Ok(match v{1=>Frame::EarthCenteredEarthFixed,2=>Frame::LocalNorthEastDown,3=>Frame::VesselReference,4=>Frame::Sensor,5=>Frame::AntennaPhaseCenter,6=>Frame::FrameIndependent,_=>return Err(JournalError::Codec("frame"))})}
