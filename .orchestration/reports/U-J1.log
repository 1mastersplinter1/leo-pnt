+        loop {
+            if self.current.is_none() {
+                let path = self.files.get(self.position)?.clone(); self.position += 1;
+                match open_checked(&path, self.kind) { Ok(f) => { self.current = Some(f); self.offset = HEADER_LEN; }, Err(e) => return Some(Err(e)) }
+            }
