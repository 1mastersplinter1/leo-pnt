+            ephemeris_snapshot_id: value.ephemeris_snapshot_id,
+            files: Vec::new(),
+        }
+    }
+}
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub enum StreamKind {
+    Measurement = 1,
+    Truth = 2,
+}
+
+impl StreamKind {
+    fn label(self) -> &'static str {
+        match self {
+            Self::Measurement => "measurement",
+            Self::Truth => "truth",
+        }
+    }
+    fn prefix(self) -> &'static str {
+        match self {
+            Self::Measurement => "measurements",
+            Self::Truth => "truth",
+        }
+    }
+}
