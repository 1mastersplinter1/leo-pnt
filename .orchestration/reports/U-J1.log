+    fn append(&mut self, kind: StreamKind, payload: Vec<u8>) -> Result<(), JournalError> {
+        if self.latched_error.is_some() { return Err(JournalError::WriterFailed); }
+        let slot = match kind { StreamKind::Measurement => &mut self.measurement, StreamKind::Truth => &mut self.truth };
+        let next = match kind { StreamKind::Measurement => &mut self.next_measurement, StreamKind::Truth => &mut self.next_truth };
+        if slot.is_none() { *slot = Some(SegmentWriter::create(&self.root, kind, *next, self.max_segment_bytes)?); }
