+#[derive(Clone, Debug, PartialEq)]
+pub enum MeasurementJournalRecord {
+    Envelope(MeasurementEnvelope),
+    Integrity(IntegrityEvent),
+    Epoch(MonotonicEpoch),
+}
+#[derive(Clone, Debug, PartialEq)]
+pub enum TruthJournalRecord {
