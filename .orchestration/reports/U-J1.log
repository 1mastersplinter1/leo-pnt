+pub struct MeasurementReader { inner: SegmentReader }
+impl MeasurementReader {
+    pub fn open(path: impl AsRef<Path>) -> Result<Self, JournalError> { Ok(Self { inner: SegmentReader::open(path.as_ref(), StreamKind::Measurement)? }) }
