+    match &x.provenance{Provenance::CaptureRecord(v)=>{e.u8(1);e.string(v)?},Provenance::SourceRecord(v)=>{e.u8(2);e.string(v)?},Provenance::DerivedRecord(v)=>{e.u8(3);e.string(v)?}}Ok(())
