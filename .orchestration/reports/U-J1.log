+impl JournalSinks for FileJournals {
+    fn write_measurement(&mut self, e: &MeasurementEnvelope) { if let Err(err) = self.try_write_measurement(e) { self.latched_error = Some(err); } }
+    fn write_truth(&mut self, e: &MeasurementEnvelope) { if let Err(err) = self.try_write_truth(e) { self.latched_error = Some(err); } }
+    fn write_integrity(&mut self, e: IntegrityEvent) { if let Err(err) = self.try_write_integrity(e) { self.latched_error = Some(err); } }
