diff --git a/tools/sitl/README.md b/tools/sitl/README.md
new file mode 100644
index 0000000000000000000000000000000000000000..816df6e9af2a16204b809b5cd256b7a1f46e9ea9
--- /dev/null
+++ b/tools/sitl/README.md
@@ -0,0 +1,27 @@
+# ArduPilot Rover SITL acceptance harness
+
+The harness pins the official ArduPilot `Rover-4.6.3` tag at commit
+`3fc7011a7d3dc047cbb17d8bd98ee94577d144c6`. `build.sh` performs a detached checkout,
+initialises the pinned tree's submodules, builds Rover SITL, and writes the resulting
+binary's SHA-256 to `ardurover.sha256`. The artifact checksum is machine/build dependent,
+so the checked-in report records the checksum observed by this unit rather than claiming a
+universal upstream binary checksum.
+
+Run from the repository root:
+
+```sh
+tools/sitl/build.sh
+tools/sitl/run.sh --duration 45 --tolerance-m 10
+```
+
+The runner wipes SITL state, confirms `FRAME_CLASS=2`, `GPS1_TYPE=14`, and `GPS2_TYPE=0`,
+reboots to activate the MAVLink GPS backend, and injects a 5 Hz straight-leg stream through
+the same mapping/send code used by the stdin bridge. It fails unless:
+
+- EKF_STATUS_REPORT has the absolute-horizontal-position bit and not constant-position mode;
+- GLOBAL_POSITION_INT finishes within 10 m of the injected position; and
+- GPS_RAW_INT exposes a finite, nonzero horizontal accuracy extension.
+
+Evidence is written to ignored `tools/sitl/evidence/sitl.log` and `mavlink.jsonl`. The
+expected final stdout is one JSON `ACCEPTANCE` record. Until a run succeeds, these outputs
+must be labelled `[UNVERIFIED — not run here]`; the runner never synthesises a passing log.
diff --git a/tools/sitl/build.sh b/tools/sitl/build.sh
new file mode 100644
index 0000000000000000000000000000000000000000..091b9a7f9e2bc3fd24e6de5b0476a6353ba323fd
--- /dev/null
+++ b/tools/sitl/build.sh
@@ -0,0 +1,22 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+SOURCE_DIR="$SCRIPT_DIR/ardupilot"
+PYTHON="$SCRIPT_DIR/../.venv/bin/python"
+PIN="3fc7011a7d3dc047cbb17d8bd98ee94577d144c6"
+
+if [[ ! -d "$SOURCE_DIR/.git" ]]; then
+    git clone --filter=blob:none --no-checkout https://github.com/ArduPilot/ardupilot.git "$SOURCE_DIR"
+fi
+git -C "$SOURCE_DIR" fetch --depth=1 origin "$PIN"
+git -C "$SOURCE_DIR" checkout --detach "$PIN"
+git -C "$SOURCE_DIR" submodule update --init --recursive --depth=1
+(
+    cd "$SOURCE_DIR"
+    "$PYTHON" ./waf configure --board sitl
+    "$PYTHON" ./waf rover
+)
+ARTIFACT="$SOURCE_DIR/build/sitl/bin/ardurover"
+test -x "$ARTIFACT"
+sha256sum "$ARTIFACT" | tee "$SCRIPT_DIR/ardurover.sha256"
