   443	    fn observe_time(&mut self, now_ns: u64) -> bool {
   444	        if self.last_now_ns.is_some_and(|last| now_ns < last) {
   445	            let old = self.state;
   446	            self.g2 = false;
   447	            self.g3 = false;
   448	            self.armed = false;
   449	            self.pending_arm_edge = false;
