   433	            && (matches!(state, AuthorityState::Nominal | AuthorityState::Caution)
   434	                || arm_enters_authority)
   435	        {
   436	            return Some(E::Disarm);
   437	        }
   438	        PRIORITY.into_iter().find(|event| {
   439	            events.contains(event) && matrix_successor(state, *event, arm_guard) != state
   440	        })
   441	    }
