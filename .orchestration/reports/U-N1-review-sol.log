   162	            receiver_clock_drift_mps: 0.0,
   163	            covariance: (0..Self::CORE_DIMENSION)
   164	                .flat_map(|row| {
   165	                    (0..Self::CORE_DIMENSION).map(move |column| f64::from(u8::from(row == column)))
   166	                })
   167	                .collect(),
   168	            covariance_dimension: Self::CORE_DIMENSION,
   169	        }
   170	    }
   171	}
