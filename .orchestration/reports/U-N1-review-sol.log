   236	fn local_horizontal_accuracy(
   237	    covariance: &[f64],
   238	    dimension: usize,
   239	    offset: usize,
   240	    position_ecef_m: [f64; 3],
   590	        } else {
   591	            self.caution_clear_since_ns = None;
   592	        }
   593	    }
   594	
   595	    fn tick(&mut self, now_ns: u64) {
   596	        if matches!(
   597	            self.state,
   598	            AuthorityState::Nominal | AuthorityState::Caution
   599	        ) && self
   600	            .lease_deadline_ns
   601	            .is_some_and(|deadline| now_ns >= deadline)
   602	        {
   603	            self.lease_deadline_ns = None;
   604	            self.apply(AuthorityEvent::LeaseExpiry, now_ns, false);
   605	        }
   606	        if self.state == AuthorityState::Warning
   607	            && self
   608	                .warning_since_ns
   609	                .zip(self.params.t_ack_s)
   610	                .is_some_and(|(start, limit)| {
   611	                    now_ns.saturating_sub(start) >= Self::seconds_ns(limit)
   612	                })
   613	        {
   614	            self.apply(AuthorityEvent::AckTimeout, now_ns, false);
   615	        }
   616	    }
   617	}
   618	
   619	impl IntegrityAuthorityGate for AuthoritySupervisor {
   620	    fn solution(&mut self, solution: AuthoritySolution<'_>, monotonic_ns: u64) {
   621	        if !self.observe_time(monotonic_ns) {
   622	            return;
   623	        }
   624	        self.evaluate_solution(solution, monotonic_ns);
   625	    }
   626	
   627	    fn steering_authorised(&mut self, _state: &FilterState, monotonic_ns: u64) -> bool {
   628	        if !self.observe_time(monotonic_ns) {
   629	            return false;
   630	        }
   631	        self.tick(monotonic_ns);
   632	        let mut output = self.output();
   633	        if output.steering_authorised
   634	            && self
   635	                .lease_deadline_ns
   636	                .is_some_and(|deadline| monotonic_ns >= deadline)
   637	        {
   638	            output.steering_authorised = false;
   639	        }
   640	        output.steering_authorised
   641	    }
   642	
   643	    fn arm_command(&mut self, command: &ArmCommand) {
   644	        if !self.observe_time(command.host_monotonic_ns) {
   645	            return;
   646	        }
   647	        match command.action {
   648	            ArmAction::Disarm => {
   649	                self.apply(AuthorityEvent::Disarm, command.host_monotonic_ns, false);
   650	            }
   651	            ArmAction::Arm
   652	                if !self.pending_arm_edge
   653	                    && matches!(
   654	                        self.state,
   655	                        AuthorityState::Disarmed | AuthorityState::LatchedSafe
   656	                    ) =>
   657	            {
   658	                self.apply(AuthorityEvent::Arm, command.host_monotonic_ns, false);
   659	            }
   660	            ArmAction::Arm => {}
   661	        }
   662	    }
   663	
   664	    fn acknowledge(&mut self, command: &AckCommand) {
   665	        self.acknowledge(command.host_monotonic_ns);
   666	    }
   667	}

