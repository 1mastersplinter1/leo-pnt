   173	impl FilterState {
   174	    pub const CORE_DIMENSION: usize = 9;
   175	
   176	    #[must_use]
   177	    pub fn horizontal_accuracy_m(&self) -> f64 {
   178	        local_horizontal_accuracy(
   179	            &self.covariance,
   180	            self.covariance_dimension,
   181	            0,
   182	            self.position_ecef_m,
   183	        )
   184	    }
   185	
