   414	            if events.contains(&fault)
   415	                && (matches!(state, AuthorityState::Nominal | AuthorityState::Caution)
   416	                    || (arm_guard
   417	                        && events.contains(&E::Arm)
   418	                        && matches!(
   419	                            state,
   420	                            AuthorityState::Disarmed | AuthorityState::LatchedSafe
   421	                        )))
   422	            {
