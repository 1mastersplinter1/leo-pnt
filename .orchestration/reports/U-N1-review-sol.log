   394	    fn decisive_event(
   395	        state: AuthorityState,
   396	        events: &[AuthorityEvent],
   397	        arm_guard: bool,
   398	    ) -> Option<AuthorityEvent> {
   399	        use AuthorityEvent as E;
   400	        const PRIORITY: [E; 11] = [
   401	            E::G3Fall,
   402	            E::G2Fall,
   403	            E::LeaseExpiry,
   404	            E::Disarm,
   405	            E::AckTimeout,
   406	            E::Acknowledge,
   407	            E::Arm,
   408	            E::G2Rise,
   409	            E::G3Rise,
   410	            E::CautionEnter,
   411	            E::CautionClear,
   412	        ];
