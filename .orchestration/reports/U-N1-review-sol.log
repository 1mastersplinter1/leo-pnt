   336	    fn apply(&mut self, event: AuthorityEvent, now_ns: u64, arm_guard: bool) {
   337	        if self.event_tick_ns != Some(now_ns) {
   338	            self.event_tick_ns = Some(now_ns);
   339	            self.event_tick_start_state = self.state;
   340	            self.event_tick_events.clear();
   341	            self.event_tick_arm_guard = false;
   342	        }
   343	        self.event_tick_events.push(event);
   344	        self.event_tick_arm_guard |= arm_guard;
   345	        let old = self.event_tick_start_state;
   346	        let new = simultaneous_successor(old, &self.event_tick_events, self.event_tick_arm_guard);
   347	        if new != self.state {
   348	            self.state = new;
   349	            let decisive_event =
   350	                Self::decisive_event(old, &self.event_tick_events, self.event_tick_arm_guard)
   351	                    .unwrap_or(event);
   352	            self.transition = Some((old, new, decisive_event));
   353	            if new == AuthorityState::Warning {
   354	                self.warning_since_ns = Some(now_ns);
   355	            }
   356	            if new == AuthorityState::LatchedSafe {
   357	                self.latched_since_ns = Some(now_ns);
   358	            }
   359	        }
   360	
   361	        // Project every mutable authority side effect from the fully merged tick outcome.
   362	        // Re-running this projection after each newly arrived same-time event prevents an
   363	        // earlier raw handler from leaving flags belonging to a superseded transition.
   364	        match new {
   365	            AuthorityState::Nominal | AuthorityState::Caution => {
   366	                self.armed = true;
   367	                self.pending_arm_edge = false;
   368	            }
   369	            AuthorityState::Disarmed
   370	            | AuthorityState::Warning
   371	            | AuthorityState::Escalated
   372	            | AuthorityState::LatchedSafe => {
   373	                self.armed = false;
   374	                self.lease_deadline_ns = None;
   375	                let fault_or_disarm = self.event_tick_events.iter().any(|event| {
   376	                    matches!(
   377	                        event,
   378	                        AuthorityEvent::G2Fall
   379	                            | AuthorityEvent::G3Fall
   380	                            | AuthorityEvent::LeaseExpiry
   381	                            | AuthorityEvent::Disarm
   382	                    )
   383	                });
   384	                self.pending_arm_edge = !fault_or_disarm
   385	                    && self.event_tick_events.contains(&AuthorityEvent::Arm)
