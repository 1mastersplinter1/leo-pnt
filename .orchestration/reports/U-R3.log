                    position_ecef_m: value.position_ecef_m,
                    velocity_ecef_mps,
                    position_variance_m2: [variance; 3],
                    velocity_variance_mps2: [variance; 3],
                    aided_mode: true,
                    chi_square_threshold: None,
                });
