        Self {
            run_uuid: value.run_uuid,
            measurement_schema_version: SCHEMA_VERSION,
            truth_schema_version: SCHEMA_VERSION,
            created_utc_rfc3339: value.created_utc_rfc3339,
            monotonic_epochs: value.monotonic_epochs,
