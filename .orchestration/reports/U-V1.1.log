+                    .into_par_iter()
+                    .map(|seed| {
+                        let mut direct = synth(LENGTH, OFFSET_HZ, 0.0, 70.0, seed);
+                        let mut echo = synth_with_reference(
+                            LENGTH,
+                            OFFSET_HZ,
+                            0.0,
+                            70.0,
+                            seed ^ 0xa5a5,
+                            REFERENCE_SEED,
+                            echo_delay,
