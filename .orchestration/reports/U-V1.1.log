+fn wilson_interval_95(successes: u64, trials: u64) -> (f64, f64) {
+    if trials == 0 {
+        return (0.0, 1.0);
+    }
+    const Z: f64 = 1.959_963_984_540_054;
+    let n = trials as f64;
+    let probability = successes as f64 / n;
+    let z_squared = Z * Z;
+    let denominator = 1.0 + z_squared / n;
