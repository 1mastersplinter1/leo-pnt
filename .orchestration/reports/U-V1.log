+    pub error_max_abs_hz: Option<f64>,
+    pub quality_p10: f64,
+    pub quality_median: f64,
+    pub quality_p90: f64,
+}
+
+#[derive(Clone, Debug, Serialize, Deserialize, PartialEq)]
+pub struct FalseAlarmStudy {
+    pub blocks: u64,
+    pub threshold_32_exceedances: u64,
+    pub observed_quantiles: Vec<Quantile>,
