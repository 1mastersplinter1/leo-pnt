+        ] {
+            assert!(value.get(key).is_some(), "missing {key}");
+        }
+    }
+
+    #[test]
+    fn fisher_model_matches_threshold_32_proposal() {
+        let probability = fisher_block_exceedance(32.0, 256, 256);
+        assert!((probability - 5.30e-9).abs() < 0.02e-9, "{probability}");
+    }
+}

