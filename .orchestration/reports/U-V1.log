+            seeds_per_cn0: 2,
+            noise_blocks: 2,
+            impairment_trials: 2,
+        });
+        let mut second = run(StudySize {
+            seeds_per_cn0: 2,
+            noise_blocks: 2,
+            impairment_trials: 2,
