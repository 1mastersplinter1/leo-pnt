+    pub variance_sweep: Vec<D39Cell>,
+    pub process_noise_sweep: Vec<D39Cell>,
+    pub geometry_sweep: Vec<D39Cell>,
+    pub observation_rate_sweep: Vec<D39Cell>,
+    pub four_way: Vec<D39Cell>,
