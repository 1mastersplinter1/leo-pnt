+#[derive(Clone, Copy)]
+struct Scenario {
+    seed: u64,
+    duration_s: u64,
+    measurement_variance: f64,
+    acceleration_variance: f64,
+    geometry_offset_s: i64,
+    observation_period_s: u64,
+    nuisance_variance: f64,
+    doppler: bool,
+    turn_at_s: Option<u64>,
+}
